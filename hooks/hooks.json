{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PY=$(command -v python3 || command -v python); [ -n \"$PY\" ] && \"$PY\" \"${CLAUDE_PLUGIN_ROOT}/skills/shrinkage/scripts/codemap.py\" refresh --auto 2>/dev/null; true"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PY=$(command -v python3 || command -v python); [ -n \"$PY\" ] && \"$PY\" \"${CLAUDE_PLUGIN_ROOT}/skills/shrinkage/scripts/progress.py\" 2>/dev/null; true"
          }
        ]
      }
    ]
  }
}
